BACKEND_IMAGE=registry.gitlab.com/ton-groupe/gestionimpression3d/backend

FRONTEND_IMAGE=registry.gitlab.com/ton-groupe/gestionimpression3d/frontend

IMAGE_TAG=latest

ASPNETCORE_ENVIRONMENT=Production

APPLY_MIGRATIONS=false

SA_PASSWORD=

JWT_KEY=

JWT_ISSUER=

JWT_AUDIENCE=

# Compte Admin créé automatiquement au tout premier démarrage (base vide uniquement).
# Change le mot de passe dès la première connexion.
ADMIN_SEED_EMAIL=
ADMIN_SEED_PASSWORD=

# URL publique du frontend utilisée dans les liens envoyés par email
FRONTEND_BASE_URL=http://localhost:4200

# SMTP transactionnel (port 587 avec STARTTLS recommandé)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=3D Inspire
SMTP_ENABLE_SSL=true
